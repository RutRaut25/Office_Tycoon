#### Solution Summary:

#### Exhibits compile-time polymorphism by mapping operators to class execution frameworks. Standard algorithmic logic

#### manipulates structural entities natively, generating dynamic results through value returns.

Complex(int r, int i) {
real = r;
img = i;
}

Complex operator+(Complex other) {
Complex res;
res.real = this->real + other.real;
res.img = this->img + other.img;
return res;
}

Complex operator-(Complex other) {
Complex res;
res.real = this->real - other.real;
res.img = this->img - other.img;
return res;
}

Complex operator*(Complex other) {
Complex res;
res.real = (this->real * other.real) - (this->img * other.img);
res.img = (this->real * other.img) + (this->img * other.real);
return res;
}

void display() {
cout << real << " + " << img << "i" << endl;
}
};

